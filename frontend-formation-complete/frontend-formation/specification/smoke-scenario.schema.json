{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loom.internal/schemas/smoke-scenario.schema.json",
  "title": "Loom Smoke Scenario",
  "type": "object",
  "required": ["scenario", "screen", "steps"],
  "properties": {
    "scenario": {"type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_-]+)+$"},
    "screen": {"type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_-]+)+$"},
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "target"],
        "properties": {
          "kind": {
            "enum": [
              "assert_initial_state",
              "perform_interaction",
              "assert_intermediate_feedback",
              "assert_terminal_state",
              "assert_contract_projection",
              "assert_accessibility_state",
              "assert_no_prohibited_side_effect"
            ]
          },
          "target": {"type": "string", "minLength": 1},
          "expected": {}
        },
        "additionalProperties": false,
        "allOf": [
          {
            "if": {"properties": {"kind": {"const": "perform_interaction"}}},
            "then": {},
            "else": {"required": ["expected"]}
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
