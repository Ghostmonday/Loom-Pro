{
  "schema_version": 1,
  "system": "loom",
  "legacy_product_name": "gaijinn",
  "description": "Loom master Intent Mapping contract. Defines the canonical user journey from vision expression through adaptive interrogation, architectural teleology (Ollivier-Ricci curvature, dark-bridge minimization), mathematically grounded blueprint synthesis, and multi-agent execution. Human UI and AI mirror drivers MUST dispatch only actions declared here and in child maps.",
  "intent_mapping_invention": {
    "principle": "One JSON map is the source of truth for browser, CLI, API smoke tests, and autonomous agents. Same triggers → same handlers → same errors.",
    "parity_target": "Mirror smoke tests without browser should achieve ≥99% behavioral parity with human flow.",
    "implementer_rule": "Do not invent routes, skip phases, or bypass gates. Wire missing pieces; do not replace the pipeline with shortcuts."
  },
  "canonical_user_journey": {
    "narrative": [
      "Vision — user expresses idea in natural language",
      "Canvas — Loom interrogates until readiness (adaptive Q&A, understanding panel)",
      "Teleology — architectural deliberation streams (curvature, bridge detect, weld plan)",
      "Blueprint — mathematically synthesized manifest (min dark bridges + LLM reasoning)",
      "Swarm — sized from work units and teleological partition",
      "Deploy — atomic multi-agent sprint",
      "Merge — collect, validate, deliverable",
      "Continuation branch — user attaches an existing repository; Loom ingests the graph, inherits prior blueprint lineage when available, and asks only for the delta",
      "Launch or Evolution — present the runnable product; Genesis launches, Continuation shows the verified update, diff, and tests"
    ],
    "mandatory_gates": [
      {"id": "gate.handoff_before_prepare", "require": "session_status == HANDED_OFF AND executable_projection present", "bypass_env": "GAIJINN_ALLOW_RAW_INTENT_PREPARE=1", "bypass_note": "Tests/local only — never production"},
      {"id": "gate.teleology_before_freeze", "require": "teleology.subphases complete OR synthesis.teleology_skipped_reason documented", "brownfield": "required", "greenfield": "required_for_graph_mode"},
      {"id": "gate.blueprint_approval", "require": "user confirms blueprint card OR auto_approve policy", "surface": "command-engine"},
      {"id": "gate.continuation_graph_before_teleology", "require": ".gaijinn/graph.json valid for attached repository OR graph.bootstrap complete", "surface": "continuation"},
      {"id": "gate.continuation_scope_before_handoff", "require": "MODIFY/ADD/DEPRECATE delta preview approved with matching blueprint_version", "surface": "continuation"}
    ]
  },
  "surfaces": {
    "vision_canvas": {
      "route": "/",
      "map": "ui/loom-intent-forge-intent-map.json",
      "status": "contract_only",
      "role": "Intent Forge — express vision, answer questions, readiness, handoff"
    },
    "command_engine": {
      "route": "/command-engine",
      "map": "ui/command-engine-ui-intent-map.json",
      "status": "contract_only",
      "role": "Teleology deliberation canvas + blueprint approval before terminal"
    },
    "terminal": {
      "route": "/terminal",
      "map": "ui/loom-ui-intent-map.json",
      "status": "contract_only",
      "role": "Sandbox frontend replacing old placeholder.html; rebuild contracts when dynamic UI lands"
    },
    "backend_pipeline": {
      "map": "ui/loom-pipeline-intent-map.json",
      "status": "contract_only",
      "role": "Headless mirror spec for full backend — no browser required"
    },
    "continuation": {
      "route": "/continuation",
      "map": "ui/loom-continuation-intent-map.json",
      "status": "contract_only",
      "role": "Attach an existing repository, ingest its graph and lineage, capture the delta, and rejoin at teleology"
    },
    "deliverable_launch": {
      "map": "ui/loom-deliverable-intent-map.json",
      "status": "contract_only",
      "role": "Present the merged product through terminal, web, or native launch and register future Continuation lineage"
    }
  },
  "child_maps": [
    "ui/loom-intent-forge-intent-map.json",
    "ui/loom-pipeline-intent-map.json",
    "ui/loom-continuation-intent-map.json",
    "ui/loom-deliverable-intent-map.json",
    "ui/loom-ui-intent-map.json",
    "ui/command-engine-ui-intent-map.json",
    "ui/process-stage-ux-map.json"
  ],
  "_ai_blueprint": {
    "comment": "Implementation guide for Codex/Cursor/Grok. Each ticket is independently verifiable via smoke_scenarios in loom-pipeline-intent-map.json.",
    "product_name": "Loom",
    "proprietary_ip": [
      "Adaptive interrogation with evidence-state reanalysis",
      "Ollivier-Ricci curvature gravity floor (CURVATURE_HARD_FLOOR = -0.30)",
      "Dark-bridge detection and weld vs HANDOFF gateway planning",
      "Architectural teleology SSE deliberation phases",
      "Executable projection from Q&A + graph synthesis fusion",
      "Multi-agent swarm partition from teleological work units"
    ],
    "layers": {
      "vision_intake": {
        "module": "aoc_supervisor/intent_forge_service.py",
        "entrypoint": "IntentForgeService.create_session",
        "status": "shipped",
        "gaps": ["UI deleted", "free tier bypasses adaptive", "answer ingestion not fully adaptive"]
      },
      "adaptive_interrogation": {
        "module": "aoc_supervisor/adaptive_question_engine.py",
        "entrypoint": "AdaptiveQuestionEngine.select_next",
        "status": "partial",
        "gaps": ["Contract says analyze_next; code uses select_next", "ANALYZING state missing", "retry_analysis endpoint missing"]
      },
      "executable_projection": {
        "module": "aoc_supervisor/workstream_planner.py",
        "entrypoint": "project_executable_blueprint",
        "status": "shipped",
        "ticket": "ENG-101"
      },
      "handoff_compiler": {
        "module": "aoc_supervisor/blueprint_compiler.py",
        "entrypoint": "compile_executable_projection",
        "status": "shipped",
        "ticket": "ENG-101"
      },
      "ollivier_ricci_curvature": {
        "module": "aoc-cli/aoc_cli/gravity.py",
        "entrypoint": "compute_gravity_and_curvature",
        "status": "shipped",
        "ticket": "ENG-103",
        "constants": {"CURVATURE_HARD_FLOOR": -0.30}
      },
      "dark_bridge_planner": {
        "module": "aoc-cli/aoc_cli/blueprint.py",
        "entrypoint": "generate_blueprint",
        "status": "shipped",
        "env_flag": "GAIJINN_HANDOFF_GATEWAYS=1",
        "goal": "Minimize dark bridges; prefer welds over orphan HANDOFF traps"
      },
      "architectural_teleology": {
        "module": "aoc_supervisor/api.py",
        "entrypoint": "GET /api/v1/blueprint/deliberate",
        "status": "shipped",
        "subphases": ["intent_parse", "graph_ingest", "curvature_compute", "bridge_detect", "weld_plan", "partition", "blueprint_freeze"]
      },
      "blueprint_synthesizer": {
        "module": "TBD — loom_blueprint_synthesizer.py",
        "entrypoint": "synthesize_blueprint",
        "status": "not_shipped",
        "ticket": "LOOM-203",
        "role": "Fuse HANDED_OFF executable_projection with gravity/curvature plan; output unified blueprint.json"
      },
      "orchestration": {
        "module": "aoc_supervisor/orchestrate_session.py",
        "entrypoint": "OrchestrateSessionStore.prepare",
        "status": "partial",
        "ticket": "ENG-104",
        "gaps": ["Skips teleology on intent_forge path", "Runs full scan/analyze even when projection injected"]
      },
      "execution": {
        "module": "aoc_supervisor/api.py",
        "entrypoint": "POST /api/v1/grid/spawn",
        "status": "shipped",
        "mock_flag": "GAIJINN_MOCK_GRID"
      },
      "merge_pipeline": {
        "module": "aoc-cli/aoc_cli/helpers/merge.py",
        "entrypoint": "merge_pipeline_status",
        "status": "shipped"
      },
      "mirror_driver": {
        "module": "aoc_supervisor/ui_intent.py",
        "entrypoint": "UiIntentDriver.run_and_verify_scenario",
        "status": "partial",
        "gaps": ["No loom full-pipeline scenario", "Intent forge steps partial"]
      }
    },
    "implementation_tickets": [
      {
        "id": "LOOM-201",
        "title": "Mandatory handoff gate on orchestrate.prepare",
        "priority": "P0",
        "files": ["aoc_supervisor/api.py", "aoc_supervisor/orchestrate_session.py"],
        "acceptance": "POST /orchestrate/prepare without intent_forge_session_id returns 409 in production; GAIJINN_ALLOW_RAW_INTENT_PREPARE=1 bypass for tests only",
        "smoke": "flow.loom_reject_raw_prepare"
      },
      {
        "id": "LOOM-202",
