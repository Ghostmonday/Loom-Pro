  "global_phases": [
    "vision_intake",
    "interrogating",
    "handoff_pending",
    "teleology_deliberating",
    "blueprint_synthesis",
    "awaiting_swarm",
    "sprinting",
    "complete",
    "failed"
  ],
  "state_machine": {
    "transitions": [
      {"from": "vision_intake", "action": "intake.start_session", "to": "interrogating"},
      {"from": "interrogating", "action": "question.submit_answer", "to": "interrogating"},
      {"from": "interrogating", "action": "handoff.confirm", "to": "handoff_pending"},
      {"from": "handoff_pending", "action": "handoff.accept", "to": "teleology_deliberating"},
      {"from": "teleology_deliberating", "action": "teleology.deliberate", "to": "blueprint_synthesis"},
      {"from": "blueprint_synthesis", "action": "blueprint.synthesize", "to": "awaiting_swarm"},
      {"from": "awaiting_swarm", "action": "orchestrate.prepare", "to": "awaiting_swarm", "note": "Loads synthesized blueprint"},
      {"from": "awaiting_swarm", "action": "swarm.select", "to": "sprinting"},
      {"from": "sprinting", "action": "grid.poll_status.terminal", "to": "complete"},
      {"from": "complete", "action": "merge.run", "to": "complete"},
      {"from": "*", "action": "pipeline.failure", "to": "failed"}
    ],
    "invariants": [
      {"id": "loom.no_prepare_without_handoff", "when": "production", "require": "orchestrate.prepare body includes intent_forge_session_id OR explicit greenfield waiver"},
      {"id": "loom.teleology_before_synthesis", "when": "blueprint_synthesis", "require": "teleology.receipt.present OR teleology.skipped_reason"},
      {"id": "loom.min_dark_bridges", "when": "blueprint frozen", "require": "blueprint.dark_bridge_count == minimum over valid partitions OR documented conflict"},
      {"id": "loom.question_exactly_one", "when": "interrogating", "require": "at most one current_question visible"}
    ]
  },
  "reasoning_and_llm_roles": {
    "interrogation": {
      "module": "aoc_supervisor/reasoning_provider.py",
      "role": "Select next question, extract claims, detect contradictions",
      "env": ["GAIJINN_REASONING_URL", "GAIJINN_FAKE_REASONING"]
    },
    "projection": {
      "module": "aoc_supervisor/workstream_planner.py",
      "role": "Turn Q&A evidence into executable workstreams"
    },
    "teleology_narration": {
      "module": "aoc_supervisor/api.py",
      "role": "Stream human-readable teleology phases during deliberation"
    },
    "coding_execution": {
      "module": "aoc_supervisor/api.py",
      "entrypoint": "POST /api/v1/grid/spawn",
      "role": "LLM agents execute partitioned work units with uniform model"
    }
  }
}
