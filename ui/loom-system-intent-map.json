        "acceptance": "/command-engine serves stepper; deliberate.start then orchestrate.prepare with intent_forge_session_id",
        "smoke": "flow.loom_command_engine_handoff"
      },
      {
        "id": "LOOM-207",
        "title": "Vision canvas UI contract",
        "priority": "P1",
