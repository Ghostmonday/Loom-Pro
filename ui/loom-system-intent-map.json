        "acceptance": "chat.submit_intent requires handoff_target query or stored forge session; prepare body includes intent_forge_session_id",
        "smoke": "flow.loom_terminal_requires_handoff"
      },
      {
        "id": "LOOM-209",
        "title": "UiIntentDriver full Loom pipeline mirror",
        "priority": "P0",
        "files": ["aoc_supervisor/ui_intent.py", "aoc_supervisor/intent_mirror.py"],
        "acceptance": "run_and_verify_scenario('flow.loom_full_pipeline_mock') passes with zero confusion",
        "smoke": "flow.loom_full_pipeline_mock"
      },
      {
        "id": "LOOM-210",
        "title": "Continuation and Launch Intent Mapping contracts",
        "priority": "P0",
        "files": ["ui/loom-continuation-intent-map.json", "ui/loom-deliverable-intent-map.json", "ui/loom-system-intent-map.json"],
        "acceptance": "Existing repositories attach without Genesis restart; graph-ready lineage can shorten or skip interrogation; continuation freezes delta_patch or refactor_partition scope; completed merges present terminal, web, or native launch and register lineage for reentry.",
        "smoke": [
          "flow.loom_continuation_attach_brownfield",
          "flow.loom_continuation_v2_lineage",
          "flow.loom_continuation_skip_interrogation",
          "flow.loom_launch_terminal",
          "flow.loom_launch_web",
          "flow.loom_reentry_after_launch"
        ]
      }
    ],
    "verification": {
      "loom_pipeline": ".venv/bin/python -m pytest tests/test_loom_pipeline_intent.py -q --no-cov",
      "full": ".venv/bin/python -m pytest -q",
      "contracts": "jq empty ui/loom-*.json ui/loom-ui-intent-map.json"
    },
