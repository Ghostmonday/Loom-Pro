        "acceptance": "HANDED_OFF session → synthesize → blueprint.json with projection_mode=loom_synthesis, dark_bridge_count minimized, teleology receipt attached",
        "smoke": "flow.loom_synthesis_min_dark_bridges"
      },
      {
        "id": "LOOM-204",
