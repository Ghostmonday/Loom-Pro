{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loom.internal/schemas/screen-manifest.schema.json",
  "title": "Loom Frontend-Formation Screen Manifest",
  "type": "object",
  "required": ["screen", "mission", "mission_id", "elements", "knowledge_bindings", "accessibility", "smoke_scenarios"],
  "properties": {
    "screen": {"type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_-]+)+$"},
    "mission": {"type": "string", "minLength": 1},
    "mission_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"},
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/definitions/element"}
    },
    "knowledge_bindings": {"$ref": "#/definitions/knowledgeBindings"},
    "accessibility": {
      "type": "object",
      "required": ["profile"],
      "properties": {
        "profile": {"enum": ["wcag-aa-strict"]},
        "custom_focus_justifications": {
          "type": "object",
          "additionalProperties": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "smoke_scenarios": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "additionalProperties": false,
  "definitions": {
    "element": {
      "type": "object",
      "required": ["id", "classification"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_:-]*$"},
        "classification": {"enum": ["action_control", "display", "presentation", "input_control"]},
        "action": {"type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_-]+)+$"},
        "contract_path": {"type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_-]+)+$"},
        "feedback_target": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_:-]*$"},
        "label": {"type": "string", "minLength": 1},
        "tag": {"enum": ["button", "div", "section", "aside", "header", "footer", "p", "span", "output", "input", "textarea"]},
        "placeholder": {"type": "string"},
        "disabled": {"type": "boolean"},
        "readonly": {"type": "boolean"},
        "name": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_:-]*$"},
        "type": {"enum": ["text", "email", "password", "search", "tel", "url", "number"]}
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"classification": {"const": "action_control"}}, "required": ["classification"]},
          "then": {"required": ["action", "feedback_target"]}
        },
        {
          "if": {"properties": {"classification": {"const": "display"}}, "required": ["classification"]},
          "then": {"required": ["contract_path"]}
        },
        {
          "if": {"properties": {"classification": {"const": "input_control"}}, "required": ["classification"]},
          "then": {
            "required": ["contract_path", "tag", "label"],
            "properties": {"tag": {"enum": ["input", "textarea"]}}
          }
        },
        {
          "if": {"properties": {"classification": {"const": "presentation"}}, "required": ["classification"]},
          "then": {
            "not": {
              "anyOf": [
                {"required": ["action"]},
                {"required": ["contract_path"]},
                {"required": ["feedback_target"]}
              ]
            }
          }
        }
      ]
    },
    "knowledgeReference": {
      "oneOf": [
        {"type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_-]+)+$"},
        {
          "type": "object",
          "required": ["status", "justification"],
          "properties": {
            "status": {"const": "not_applicable"},
            "justification": {"type": "string", "minLength": 10}
          },
          "additionalProperties": false
        }
      ]
    },
    "knowledgeBindings": {
      "type": "object",
      "required": ["design_intent", "behavioral", "operational", "governance", "institutional"],
      "properties": {
        "design_intent": {"$ref": "#/definitions/knowledgeReference"},
        "behavioral": {"$ref": "#/definitions/knowledgeReference"},
        "operational": {"$ref": "#/definitions/knowledgeReference"},
        "governance": {"$ref": "#/definitions/knowledgeReference"},
        "institutional": {"$ref": "#/definitions/knowledgeReference"}
      },
      "additionalProperties": false
    }
  }
}
