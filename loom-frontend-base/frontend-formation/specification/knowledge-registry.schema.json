{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loom.internal/schemas/knowledge-registry.schema.json",
  "title": "Loom Knowledge Binding Registry",
  "type": "object",
  "required": ["bindings"],
  "properties": {
    "bindings": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z0-9]+(\\.[a-z0-9_-]+)+$": {
          "type": "object",
          "required": ["domain", "description"],
          "properties": {
            "domain": {"enum": ["design_intent", "behavioral", "operational", "governance", "institutional"]},
            "description": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
