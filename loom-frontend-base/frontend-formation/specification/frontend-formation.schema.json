{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loom.internal/schemas/frontend-formation.schema.json",
  "title": "Frontend-Formation Project Configuration",
  "type": "object",
  "required": ["rule_set_version", "action_registry", "knowledge_registry", "screens"],
  "properties": {
    "rule_set_version": {"const": "1.0.0"},
    "action_registry": {"type": "string", "minLength": 1},
    "knowledge_registry": {"type": "string", "minLength": 1},
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["manifest", "html"],
        "properties": {
          "manifest": {"type": "string", "minLength": 1},
          "html": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
