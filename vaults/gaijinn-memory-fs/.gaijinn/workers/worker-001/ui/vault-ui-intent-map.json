        "council.md updated with vault results",
        "events.md updated with vault results"
      ]
    },
    {
      "id": "vault.full_loop_mock",
      "description": "Full vault memory execution loop: learn -> act -> measure -> promote -> distill",
      "requires": {"GAIJINN_MOCK_GRID": "1"},
      "steps": [
        {"action": "loop.learn", "paths": ["40_Concepts/"]},
        {"action": "loop.act", "cli": "gaijinn scan ."},
        {"action": "loop.measure", "checks": ["convergence"]},
        {"action": "promotion.validate", "cli": "python 10_Operations/agents/promoter/validate_promotion.py --batch pending/ --vault-root . --report-json"},
        {"action": "vault.lint", "cli": "python 10_Operations/knowledge-linter.py"},
        {"action": "loop.distill", "targets": ["_multi-agent/events.md"]}
      ],
      "assertions": [
        "vault.lint exit_code == 0",
        "validator result == PASS or warnings-only",
        "events.md updated with vault.lint results"
      ]
    },
    {
      "id": "vault.promotion_gate_check",
      "description": "Verify promotion gates pass before concept progression",
      "requires": {"GAIJINN_MOCK_GRID": "1"},
      "steps": [
        {"action": "promotion.validate", "cli": "python 10_Operations/agents/promoter/validate_promotion.py --batch pending/ --vault-root . --report-json --convergence-threshold 0.875"},
        {"action": "vault.lint", "cli": "python 10_Operations/knowledge-linter.py --check"}
      ],
      "assertions": [
        "validator result == PASS or passes >= pending_count",
        "no shadow bridges in linter output",
        "convergence gate passes (dry-run threshold 0.875)"
      ]
    },
    {
      "id": "vault.deepseek_executor_mock",
      "description": "Vault-specific deepseek executor validation through full loop",
      "requires": {"GAIJINN_MOCK_GRID": "1", "GAIJINN_PROJECT_ROOT": "vaults/gaijinn-memory-fs"},
      "steps": [
        {"action": "orchestrate.prepare", "args": {"intent": "Vault memory cycle - validate executor profile"}},
        {"action": "orchestrate.swarm", "args": {"workers": 2}},
        {"action": "deploy.sprint", "args": {"workers": 2, "executor": "deepseek", "model": "deepseek-v4-flash", "task": "Vault executor validation"}},
        {"action": "grid.poll_status", "until": "completed"},
        {"action": "promotion.validate", "cli": "python 10_Operations/agents/promoter/validate_promotion.py --batch pending/ --vault-root . --report-json"},
        {"action": "vault.lint", "cli": "python 10_Operations/knowledge-linter.py"}
      ],
      "assertions": [
        "spawn.executor == deepseek",
        "spawn.model == deepseek-v4-flash",
        "validator result == PASS or warnings-only",
        "vault.lint exit_code == 0 or pre-existing only"
      ]
    },
    {
      "id": "vault.three_gates_mock",
      "description": "Verify three-gate pipeline: mirror smoke -> perf bench -> human sign-off",
      "requires": {"GAIJINN_MOCK_GRID": "1"},
      "steps": [
        {"action": "gate.mirror_smoke", "script": "scripts/dev/ui-intent-smoke.sh", "retry": 2},
        {"action": "gate.perf_bench", "script": "scripts/dev/perf-bench.sh", "retry": 1}
      ],
      "assertions": [
        "confusion_count == 0",
        "perf-bench-results.json exists and all thresholds met",
        "human-signoff.md exists or deferred to next sprint"
      ]
    },
    {
      "id": "vault.resilience_mock",
      "description": "Verify circuit breaker opens and recovers after consecutive failures",
      "requires": {"GAIJINN_MOCK_GRID": "1"},
      "steps": [
        {"action": "deploy.spawn", "args": {"workers": 3, "fail_count": 3}},
        {"action": "recover.circuit_breaker", "script": "scripts/dev/circuit-breaker-recovery.sh", "timeout_seconds": 60},
        {"action": "deploy.spawn", "args": {"workers": 1, "executor": "deepseek"}}
      ],
      "assertions": [
        "circuit_breaker state == open after 3 failures",
        "circuit_breaker state == closed after recovery",
        "last spawn succeeds with normal executor"
      ]
    }
  ]
}
