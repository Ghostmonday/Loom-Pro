  "disaster_recovery": {
    "description": "Recovery procedures for grid worker failures, merge failures, and vault corruption",
    "procedures": [
      {
        "id": "recover.worker_crash",
        "trigger": "worker PID file stale (process not running)",
        "steps": [
          "Remove stale lock file",
          "Remove stale spawn PID file",
          "Fix hermes-loop-state.json: set phase to appropriate recovery phase",
          "Fix manifest.json: add status=completed to finished workers",
          "Resume from last completed checkpoint"
        ],
        "validation": "spawn_count == worker_count AND all workers have status in (completed, failed)"
      },
      {
        "id": "recover.merge_failure",
        "trigger": "merge-grid exit != 0 or structural_score convergence < threshold",
        "steps": [
          "Read merge governance.json for blocking workers",
          "Inspect blocked workers' output in .gaijinn/workers/",
          "OCC replay: re-run collect + validate-worker on failing workers",
          "Re-merge with --strategy sequential",
          "Verify convergence >= 0.875 (dry-run) or >= 1.0 (production)"
        ],
        "validation": "merge exit == 0 AND convergence >= threshold"
      },
      {
        "id": "recover.vault_linter_violation",
        "trigger": "knowledge-linter.py exit != 0",
        "steps": [
          "Capture linter output for each violating file",
          "Check for orphan wikilinks, missing frontmatter, broken OCC chain",
          "Repair each violation in its owning worker's workspace",
          "Re-run linter with --check flag",
          "Only promote after linter passes clean"
        ],
        "validation": "knowledge-linter.py --check exit == 0"
      },
      {
        "id": "recover.dual_ledger_desync",
        "trigger": "events.md and council.md diverge on sprint state",
        "steps": [
          "Diff both ledgers: compare latest entries by timestamp",
          "Identify the authoritative ledger (council.md for operational, events.md for semantic)",
          "Merge missing entries into the lagging ledger",
          "Verify both ledgers agree on current sprint_id and phase"
        ],
        "validation": "ledger entries match on sprint_id, phase, and worker_count"
      },
      {
        "id": "recover.circuit_breaker_trip",
        "trigger": "3 consecutive grid spawn failures within 300s",
        "steps": [
          "Open circuit: stop all new spawn attempts",
          "Log diagnostic info: model, provider, timeout",
          "Wait 60s recovery_timeout",
          "Attempt half-open: 1 spawn with fallback executor",
          "If half-open succeeds: close circuit, resume normal operation",
          "If half-open fails: escalate to hermes-default interactive mode"
        ],
        "validation": "circuit_breaker state == closed AND last spawn succeeded"
      }
    ]
  },
